# ── Honcho Self-Hosted Configuration ──
# Copy this file to .env and fill in your values.
# All variables are optional unless marked REQUIRED.

# ── Database (ParadeDB) ──
DB_USER=honcho
DB_PASSWORD=honcho
DB_NAME=honcho
DB_PORT=5432

# ── Redis ──
REDIS_PORT=6379

# ── API Server ──
API_PORT=8000

# ── Auth (set AUTH_USE_AUTH=true to enable JWT-based authentication) ──
AUTH_USE_AUTH=false
# AUTH_JWT_SECRET=your-secret-here  # REQUIRED if AUTH_USE_AUTH=true

# ── LLM Providers (at least one REQUIRED for Deriver/Dialectic/Dreamer agents) ──
# Honcho uses LLMs to extract observations from messages and answer queries.
# You can skip setting LLM keys if you only use Honcho for message storage/retrieval.
LLM_OPENAI_API_KEY=
LLM_ANTHROPIC_API_KEY=
# LLM_GEMINI_API_KEY=

# ── Embedding (for vector similarity search) ──
EMBEDDING_TRANSPORT=openai        # openai | gemini
EMBEDDING_MODEL=text-embedding-3-small

# ── Server Identity ──
BASE_URL=http://localhost:8000     # Public-facing URL for OpenAPI docs / CORS
CONTACT_EMAIL=                     # Shown in OpenAPI docs

# ── Logging ──
LOG_LEVEL=INFO                     # DEBUG | INFO | WARNING | ERROR

# ── Optional: Telemetry (disabled by default for self-hosted) ──
# TELEMETRY_ENABLED=false

# ── Optional: Sentry error tracking ──
# SENTRY_ENABLED=false
# SENTRY_DSN=
