# Honcho — full Rust stack (Docker Compose)
#
# This brings up the Rust port end to end: the API server (honcho-api-rs) and
# the queue worker (honcho-deriver), both built from ./api-rs, plus the Rust
# MCP server, Postgres (pgvector) and Redis. There is NO Python service here —
# for the Python stack use docker-compose.yml.example instead.
#
# Usage:
#   cp docker-compose-rs.yml.example docker-compose-rs.yml
#   cp .env.template .env  # set DB / provider / LLM keys
#   docker compose -f docker-compose-rs.yml up -d --build
#
# By default, ports are bound to 127.0.0.1 (localhost only).
#
# NOTE: the API server and the worker are the SAME image (./api-rs builds both
# the honcho-api-rs and honcho-deriver binaries); the worker just overrides the
# command. Run exactly ONE deriver against a given database queue — do not run
# this worker alongside the Python deriver on the same DB.

services:
  # One-shot schema provisioning. The Rust stack does NOT run migrations; it
  # reuses the Python alembic migrations via this short-lived job so the schema
  # is byte-identical to the Python deployment. It runs, applies migrations,
  # and exits; api/deriver wait for it to complete successfully. This is the
  # one piece of Python in the otherwise all-Rust stack.
  migrate:
    build:
      context: .
      dockerfile: Dockerfile
    command: ["/app/.venv/bin/python", "scripts/provision_db.py"]
    depends_on:
      database:
        condition: service_healthy
    environment:
      - DB_CONNECTION_URI=postgresql+psycopg://postgres:postgres@database:5432/postgres
      - DB_SCHEMA=${DB_SCHEMA:-public}
    env_file:
      - path: .env
        required: false
    restart: "no"

  api:
    build:
      context: ./api-rs
      dockerfile: Dockerfile
    command: ["honcho-api-rs"]
    depends_on:
      migrate:
        condition: service_completed_successfully
      database:
        condition: service_healthy
      redis:
        condition: service_healthy
    ports:
      - "127.0.0.1:8000:8000"
    healthcheck:
      test:
        ["CMD", "curl", "-fsS", "http://localhost:8000/health"]
      interval: 5s
      timeout: 5s
      retries: 5
      start_period: 10s
    environment:
      - RUST_API_BIND_ADDRESS=0.0.0.0:8000
      - DB_CONNECTION_URI=postgresql+psycopg://postgres:postgres@database:5432/postgres
      - DB_SCHEMA=${DB_SCHEMA:-public}
      - AUTH_USE_AUTH=${AUTH_USE_AUTH:-false}
      - AUTH_JWT_SECRET=${AUTH_JWT_SECRET:-}
      # The Rust API defaults to read-only; flip to true to enable write routes.
      - RUST_API_ENABLE_WRITES=${RUST_API_ENABLE_WRITES:-true}
      - NAMESPACE=${NAMESPACE:-honcho}
      - CACHE_ENABLED=${CACHE_ENABLED:-true}
      - CACHE_URL=${CACHE_URL:-redis://redis:6379/0?suppress=true}
      - CACHE_NAMESPACE=${CACHE_NAMESPACE:-}
      # Providers (chat completion + embedding). Set the keys for whatever you use.
      - LLM_ANTHROPIC_API_KEY=${LLM_ANTHROPIC_API_KEY:-}
      - LLM_OPENAI_API_KEY=${LLM_OPENAI_API_KEY:-}
      - LLM_GEMINI_API_KEY=${LLM_GEMINI_API_KEY:-}
      - EMBEDDING_PROVIDER=${EMBEDDING_PROVIDER:-openai}
      - WEBHOOK_SECRET=${WEBHOOK_SECRET:-}
    env_file:
      - path: .env
        required: false
    restart: unless-stopped

  deriver:
    build:
      context: ./api-rs
      dockerfile: Dockerfile
    # Same image as `api`, different binary — the background queue worker
    # (porting `python -m src.deriver`). Processes representation, deletion,
    # summary, reconciler, webhook and dream work units.
    command: ["honcho-deriver"]
    depends_on:
      migrate:
        condition: service_completed_successfully
      api:
        condition: service_healthy
      database:
        condition: service_healthy
      redis:
        condition: service_healthy
    environment:
      - DB_CONNECTION_URI=postgresql+psycopg://postgres:postgres@database:5432/postgres
      - DB_SCHEMA=${DB_SCHEMA:-public}
      - CACHE_ENABLED=${CACHE_ENABLED:-true}
      - CACHE_URL=${CACHE_URL:-redis://redis:6379/0?suppress=true}
      - CACHE_NAMESPACE=${CACHE_NAMESPACE:-}
      - LLM_ANTHROPIC_API_KEY=${LLM_ANTHROPIC_API_KEY:-}
      - LLM_OPENAI_API_KEY=${LLM_OPENAI_API_KEY:-}
      - LLM_GEMINI_API_KEY=${LLM_GEMINI_API_KEY:-}
      - EMBEDDING_PROVIDER=${EMBEDDING_PROVIDER:-openai}
      - WEBHOOK_SECRET=${WEBHOOK_SECRET:-}
      - DREAM_ENABLED=${DREAM_ENABLED:-true}
      - RUST_LOG=${RUST_LOG:-info}
    env_file:
      - path: .env
        required: false
    restart: unless-stopped

  mcp:
    build:
      context: ./mcp-rs
      dockerfile: Dockerfile
    depends_on:
      api:
        condition: service_healthy
    ports:
      - "127.0.0.1:8787:8787"
    environment:
      - HONCHO_API_URL=http://api:8000
      - MCP_BIND_ADDRESS=0.0.0.0:8787
    restart: unless-stopped

  database:
    image: pgvector/pgvector:pg15
    restart: unless-stopped
    ports:
      - "127.0.0.1:5432:5432"
    command: ["postgres", "-c", "max_connections=200"]
    environment:
      - POSTGRES_DB=postgres
      - POSTGRES_USER=postgres
      - POSTGRES_PASSWORD=postgres
      # Allow passwordless connections from the host (port is bound to 127.0.0.1).
      # Lets the local test suite and ad-hoc tools connect without supplying a
      # password. Do NOT use this in production.
      - POSTGRES_HOST_AUTH_METHOD=trust
      - PGDATA=/var/lib/postgresql/data/pgdata
    volumes:
      - ./database/init.sql:/docker-entrypoint-initdb.d/init.sql
      - pgdata:/var/lib/postgresql/data/
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U postgres -d postgres"]
      interval: 5s
      timeout: 5s
      retries: 5

  redis:
    image: redis:8.2
    restart: unless-stopped
    ports:
      - "127.0.0.1:6379:6379"
    volumes:
      - redis-data:/data
    healthcheck:
      test: ["CMD-SHELL", "redis-cli ping"]
      interval: 5s
      timeout: 5s
      retries: 5

volumes:
  pgdata:
  redis-data:
